# ================================
# LLM Configuration (Gemini)
# ================================

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Optional fallback model
GEMINI_FALLBACK_MODEL=gemini-1.5-pro

# ================================
# LangChain / Agent Settings
# ================================

AGENT_MAX_ITERATIONS=5
AGENT_TEMPERATURE=0.2

# Enable verbose reasoning logs
AGENT_VERBOSE=true

# ================================
# Vector Database (Chroma)
# ================================

VECTOR_DB_PATH=./vector_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ================================
# Document Storage
# ================================

DOCUMENTS_PATH=./data/reports
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ================================
# Backend API (Structural Models)
# ================================

STRUCTURAL_API_URL=http://localhost:8000

# endpoints your agent can call
RISK_ENDPOINT=/risk-score
ANOMALY_ENDPOINT=/detect-anomaly
SENSOR_ENDPOINT=/sensor-data
DIGITAL_TWIN_ENDPOINT=/simulate

# ================================
# FastAPI Server
# ================================

API_HOST=0.0.0.0
API_PORT=6969

# ================================
# Environment
# ================================

ENVIRONMENT=development
LOG_LEVEL=info